cat > release.sh << 'EOF'
#!/bin/bash

# Release workflow automation
release() {
    local release_type=$1
    local release_notes=$2
    
    if [ -z "$release_type" ]; then
        echo "Usage: $0 {major|minor|patch} 'release notes'"
        exit 1
    fi
    
    echo "=== Starting Release Process ==="
    
    # TODO: Verify working directory is clean
    # TODO: Bump version
    # TODO: Update changelog
    # TODO: Commit version changes
    # TODO: Run build
    # TODO: Create and push tag
    
    # Check for uncommitted changes
    if ! git diff-index --quiet HEAD --; then
        echo "Error: Working directory has uncommitted changes"
        exit 1
    fi
    
    # Bump version
    ./version-manager.sh bump "$release_type"
    new_version=$(./version-manager.sh get)
    
    # Update changelog
    if [ -n "$release_notes" ]; then
        echo "## Version $new_version - $(date +%Y-%m-%d)" >> CHANGELOG.md
        echo "$release_notes" >> CHANGELOG.md
        echo "" >> CHANGELOG.md
    fi
    
    # Commit version bump
    git add VERSION CHANGELOG.md
    git commit -m "Bump version to $new_version"
    
    # Build artifact
    ./build.sh
    
    # Add build artifacts to git (optional, usually stored elsewhere)
    git add builds/ metadata/
    git commit -m "Add build artifacts for version $new_version"
    
    echo ""
    echo "=== Release Complete ==="
    echo "Version: $new_version"
    echo "Tag: v$new_version"
    echo ""
    echo "To push to remote: git push && git push --tags"
}

release "$@"
EOF

