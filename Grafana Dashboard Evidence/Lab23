Step 3.5: Export Dashboard JSON
# Get dashboard UID from Grafana UI or API
# Export dashboard configuration
curl -u admin:admin http://localhost:3000/api/dashboards/uid/YOUR_DASHBOARD_UID > ~/grafana-evidence/system-performance-dashboard.json

# Alternative: Export all dashboards
curl -u admin:admin http://localhost:3000/api/search?type=dash-db | \
  jq -r '.[] | .uid' | \
  while read uid; do
    curl -u admin:admin http://localhost:3000/api/dashboards/uid/$uid > ~/grafana-evidence/dashboard-$uid.json
  done
Step 3.6: Create Evidence Summary
# Generate metrics summary
tee ~/grafana-evidence/metrics-summary.txt > /dev/null <<EOF
=== Grafana Dashboard Evidence Summary ===

Timestamp: $(date)

Services Status:
$(sudo systemctl is-active grafana-server prometheus node_exporter)

Active Metrics:
$(curl -s http://localhost:9090/api/v1/targets | jq '.data.activeTargets | length') targets

Dashboard Count:
$(curl -s -u admin:admin http://localhost:3000/api/search?type=dash-db | jq '. | length') dashboards

Sample Metrics:
- CPU: $(curl -s 'http://localhost:9090/api/v1/query?query=100-(avg(irate(node_cpu_seconds_total{mode="idle"}[5m]))*100)' | jq -r '.data.result[0].value[1]')%
- Memory Used: $(free -h | awk '/^Mem:/ {print $3}')
- Disk Usage: $(df -h / | awk 'NR==2 {print $5}')

EOF

cat ~/grafana-evidence/metrics-summary.txt
Step 3.7: Package Evidence
# Create archive of all evidence
cd ~
tar -czf grafana-lab-evidence.tar.gz grafana-evidence/

# Display archive contents
echo "=== Evidence Package Contents ==="
tar -tzf grafana-lab-evidence.tar.gz

# Show file sizes
ls -lh grafana-lab-evidence.tar.gz
Verification
Verify Grafana Installation
# Check Grafana version
grafana-server -v

# Verify service status
sudo systemctl status grafana-server --no-pager | grep Active
Expected: Active: active (running)

Verify Data Collection
# Check Prometheus targets
curl -s http://localhost:9090/api/v1/targets | jq '.data.activeTargets[] | {job: .labels.job, health: .health}'

# Verify metrics are being collected
curl -s 'http://localhost:9090/api/v1/query?query=up' | jq '.data.result'
Expected: All targets should show "health": "up"

Verify Dashboards
# List all dashboards
curl -s -u admin:admin http://localhost:3000/api/search?type=dash-db | jq '.[] | {title: .title, uid: .uid}'

# Check dashboard count
curl -s -u admin:admin http://localhost:3000/api/search?type=dash-db | jq '. | length'
Expected: At least 2 dashboards created

Verify Evidence Files
# Check evidence directory
ls -lh ~/grafana-evidence/

# Verify archive
tar -tzf ~/grafana-lab-evidence.tar.gz | wc -l
Expected: Multiple files including markdown documentation and JSON exports

Troubleshooting
Issue: Grafana won't start

# Check logs
sudo journalctl -u grafana-server -n 50

# Verify port availability
sudo netstat -tlnp | grep 3000
Issue: No data in dashboards

# Verify Prometheus is scraping
curl http://localhost:9090/api/v1/targets

# Check Node Exporter metrics
curl http://localhost:9100/metrics | head -n 20
Issue: Cannot connect to data source

# Test Prometheus connectivity
curl http://localhost:9090/api/v1/query?query=up

# Restart services
sudo systemctl restart prometheus grafana-server
Issue: Screenshots not capturing

# Alternative: Use Grafana's built-in export
# Navigate to dashboard > Share > Export > Save to file
Conclusion
You have successfully:

Installed and configured a complete monitoring stack (Grafana, Prometheus, Node Exporter)
Created operational dashboards visualizing CPU, memory, disk, and network metrics
Configured multiple panel types including time series, bar gauges, and stats
Captured and documented dashboard evidence with screenshots and exports
Generated a comprehensive evidence package for audit or review purposes
Real-World Significance: DevOps engineers use Grafana dashboards to monitor production systems, identify performance bottlenecks, and provide evidence of system health to stakeholders. The ability to create, customize, and document dashboards is essential for maintaining reliable infrastructure and meeting compliance requirements.

