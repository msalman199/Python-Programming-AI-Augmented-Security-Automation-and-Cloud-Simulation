sudo chown $USER:$USER /var/www/incident-app

cat > /var/www/incident-app/index.html << 'EOF'
<!DOCTYPE html>
<html>
<head><title>Incident Drill App</title></head>
<body>
<h1>Application Running</h1>
<p>Status: Operational</p>
</body>
</html>
EOF
Configure Nginx:

sudo tee /etc/nginx/sites-available/incident-app << 'EOF'
server {
    listen 8080;
    server_name localhost;
    root /var/www/incident-app;
    index index.html;
    
    access_log /var/log/nginx/incident-app-access.log;
    error_log /var/log/nginx/incident-app-error.log;
}
EOF

sudo ln -sf /etc/nginx/sites-available/incident-app /etc/nginx/sites-enabled/
sudo nginx -t
sudo systemctl restart nginx
