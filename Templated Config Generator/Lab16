sudo apt install -y python3 python3-pip python3-venv

# Create project directory
mkdir -p ~/config-generator
cd ~/config-generator

# Create virtual environment
python3 -m venv venv
source venv/bin/activate

# Install required packages
pip install jinja2 pyyaml jsonschema
Task 1: Build Template-Based Configuration Generator
Step 1: Create Project Structure
cd ~/config-generator
mkdir -p templates configs data schemas
touch generator.py validator.py
Step 2: Create Configuration Templates
Create a Nginx server template:

cat > templates/nginx.conf.j2 << 'EOF'
# Nginx Configuration for {{ app_name }}
# Environment: {{ environment }}

upstream {{ app_name }}_backend {
    {% for server in backend_servers %}
    server {{ server.host }}:{{ server.port }} weight={{ server.weight | default(1) }};
    {% endfor %}
}

server {
    listen {{ listen_port }};
    server_name {{ server_name }};
    
    {% if ssl_enabled %}
    ssl_certificate {{ ssl_cert_path }};
    ssl_certificate_key {{ ssl_key_path }};
    {% endif %}
    
    location / {
        proxy_pass http://{{ app_name }}_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        {% if custom_headers %}
        {% for header, value in custom_headers.items() %}
        proxy_set_header {{ header }} {{ value }};
        {% endfor %}
        {% endif %}
    }
    
    access_log /var/log/nginx/{{ app_name }}_access.log;
    error_log /var/log/nginx/{{ app_name }}_error.log;
}
EOF
Create an application configuration template:

cat > templates/app_config.yaml.j2 << 'EOF'
# Application Configuration
application:
  name: {{ app_name }}
  environment: {{ environment }}
  version: {{ version }}

database:
  host: {{ db_host }}
  port: {{ db_port }}
  name: {{ db_name }}
  pool_size: {{ db_pool_size | default(10) }}
  {% if environment == 'production' %}
  ssl_mode: require
  {% else %}
  ssl_mode: prefer
  {% endif %}

cache:
  enabled: {{ cache_enabled | default(true) }}
  {% if cache_enabled %}
  type: {{ cache_type | default('redis') }}
  host: {{ cache_host }}
  port: {{ cache_port | default(6379) }}
  ttl: {{ cache_ttl | default(3600) }}
  {% endif %}

logging:
  level: {{ log_level | default('INFO') }}
  format: {{ log_format | default('json') }}
  outputs:
    {% for output in log_outputs %}
    - {{ output }}
    {% endfor %}
EOF
