Environment Setup
Step 1: Install Required Tools
# Update system packages
sudo apt update

# Install Python and pip
sudo apt install -y python3 python3-pip git

# Install required Python libraries
pip3 install pyyaml jsonschema deepdiff
Step 2: Create Lab Directory Structure
# Create working directory
mkdir -p ~/golden-config-lab/{golden,current,scripts,logs}
cd ~/golden-config-lab
Task 1: Create Golden Configuration Standards
Step 1.1: Define Golden Configuration Templates
Create a golden configuration for a web server:

cat > golden/webserver_golden.yaml << 'EOF'
service:
  name: nginx
  version: "1.18+"
  state: running
  enabled: true

security:
  firewall:
    enabled: true
    allowed_ports:
      - 80
      - 443
  ssl:
    enabled: true
    min_tls_version: "1.2"
  
network:
  listen_address: "0.0.0.0"
  max_connections: 1024
  timeout: 30

logging:
  level: "info"
  path: "/var/log/nginx"
  rotation: "daily"
  retention_days: 30
EOF
Create a golden configuration for SSH service:

cat > golden/ssh_golden.yaml << 'EOF'
service:
  name: sshd
  port: 22
  state: running

security:
  permit_root_login: false
  password_authentication: false
  pubkey_authentication: true
  max_auth_tries: 3
  
hardening:
  protocol: 2
  x11_forwarding: false
  use_pam: true
  client_alive_interval: 300
EOF
Step 1.2: Create Configuration Schema Validator
Create a JSON schema for validation:

cat > golden/config_schema.json << 'EOF'
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["service", "security"],
  "properties": {
    "service": {
      "type": "object",
      "required": ["name", "state"]
    },
    "security": {
      "type": "object",
      "minProperties": 1
    }
  }
}
EOF
